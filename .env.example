# Copy to .env or env.local — NEVER commit real secrets.

# OpenAI — provide one of the two:
OPENAI_API_KEY=
OPEN_API=

# LangSmith observability (optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=sa-underwriting

# Credit bureaus — set CREDIT_USE_MOCK=true for local dev
CREDIT_USE_MOCK=true
TRANSUNION_BASE_URL=https://api.transunion.example
TRANSUNION_API_KEY=
EXPERIAN_BASE_URL=https://api.experian.example
EXPERIAN_API_KEY=

# ML model overrides (leave blank to use artifacts/*)
ML_MODEL_PATH=
DELINQ_MODEL_PATH=

# Extraction model override (default: gpt-4o-mini from config/prompts.yaml)
EXTRACTION_MODEL=

# Config directory override (default: ./config)
UNDERWRITING_CONFIG_DIR=

# Kafka (optional – used by services/events.py if set)
KAFKA_BOOTSTRAP_SERVERS=
